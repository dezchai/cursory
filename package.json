{
  "name": "@dezchai/cursory",
  "version": "0.1.1",
  "description": "Bun/TypeScript port of cursory for generating realistic mouse trajectories.",
  "keywords": [
    "bot",
    "bots",
    "botting",
    "browser",
    "cursor",
    "mouse",
    "mouse-trajectory",
    "patchright",
    "playwright",
    "stealth",
    "trajectory",
    "trajectory-generation",
    "undetectable",
    "undetected",
    "web-automation",
    "web-scraping",
    "webautomation",
    "webdriver",
    "webscraping"
  ],
  "license": "GPL-3.0-or-later",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dezchai/cursory.git"
  },
  "homepage": "https://github.com/dezchai/cursory",
  "bugs": {
    "url": "https://github.com/dezchai/cursory/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "data",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/bun": "^1.3.11",
    "typescript": "^5.9.3"
  }
}
